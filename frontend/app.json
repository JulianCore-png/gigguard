{
  "expo": {
    "name": "Gig-Guard",
    "slug": "gigguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gigguard",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Track miles driven during your shift for tax deductions",
        "NSCameraUsageDescription": "Snap receipts for one-tap expense tracking",
        "NSPhotoLibraryUsageDescription": "Pick receipt photos from your library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E11"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E11"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Track miles driven during your shift for tax deductions"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Snap receipts for one-tap expense tracking"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick receipt photos from your library"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
